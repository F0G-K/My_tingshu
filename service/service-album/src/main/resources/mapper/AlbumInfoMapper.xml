<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >


<mapper namespace="com.atguigu.tingshu.album.mapper.AlbumInfoMapper">

    <resultMap id="AlbumListVoMap" type="com.atguigu.tingshu.vo.album.AlbumListVo">
        <id column="album_id" property="albumId"/>
        <result column="album_title" property="albumTitle"/>
        <result column="cover_url" property="coverUrl"/>
        <result column="include_track_count" property="includeTrackCount"/>
        <result column="is_finished" property="isFinished"/>
        <result column="status" property="status"/>
        <result column="play_stat_num" property="playStatNum"/>
        <result column="subscribe_stat_num" property="subscribeStatNum"/>
        <result column="buy_stat_num" property="buyStatNum"/>
        <result column="comment_stat_num" property="commentStatNum"/>
    </resultMap>

    <!-- 分页查询用户专辑列表,行转列聚合统计:0401-播放 0402-订阅 0403-购买 0404-评论 -->
    <select id="selectUserAlbumPage" resultMap="AlbumListVoMap">
        SELECT
            ai.id AS album_id,
            ai.album_title,
            ai.cover_url,
            ai.include_track_count,
            ai.is_finished,
            ai.status,
            MAX(IF(stat.stat_type = '0401', stat.stat_num, 0)) AS play_stat_num,
            MAX(IF(stat.stat_type = '0402', stat.stat_num, 0)) AS subscribe_stat_num,
            MAX(IF(stat.stat_type = '0403', stat.stat_num, 0)) AS buy_stat_num,
            MAX(IF(stat.stat_type = '0404', stat.stat_num, 0)) AS comment_stat_num
        FROM album_info ai
        LEFT JOIN album_stat stat ON stat.album_id = ai.id AND stat.is_deleted = 0
        <where>
            ai.is_deleted = 0
            <if test="vo.userId != null">
                AND ai.user_id = #{vo.userId}
            </if>
            <if test="vo.albumTitle != null and vo.albumTitle != ''">
                AND ai.album_title LIKE CONCAT('%', #{vo.albumTitle}, '%')
            </if>
            <if test="vo.status != null and vo.status != ''">
                AND ai.status = #{vo.status}
            </if>
        </where>
        GROUP BY ai.id
        ORDER BY ai.id DESC
    </select>

</mapper>
